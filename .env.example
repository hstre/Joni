# Joni runs fully offline by default with a deterministic MockModel - no key needed.
# State, operators, routing and the ledger are deterministic regardless of the model.
#
# To give the outer voice a real model (it only rephrases a state-grounded brief,
# never invents facts), install the extra and set a key:
#   pip install -e ".[llm]"
# DEEPSEEK_API_KEY (or DEEPSEEK_API_KEY2) takes priority; else OPENAI_API_KEY.
JONI_USE_REAL_LLM=0
# DEEPSEEK_API_KEY=sk-...      # DEEPSEEK_API_KEY2 also accepted
# OPENAI_API_KEY=sk-...
# Transient-failure retry for the real voice:
# JONI_LLM_RETRIES=4
# JONI_LLM_BACKOFF=0.5

# Creativity engine. Default is the deterministic local engine. Set to 1 to plug in
# the sibling Kevin creativity-routing engine (install it first, e.g. pip install -e ../Kevin).
JONI_USE_KEVIN=0

# Persistence: where the identity is saved so it lives on across restarts (JSON).
# Default: ~/.joni/state.json
# JONI_STATE=/path/to/state.json

# Web server (joni-serve)
# JONI_HOST=127.0.0.1
# JONI_PORT=8000
